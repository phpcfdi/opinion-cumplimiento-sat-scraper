{
  "name": "phpcfdi/opinion-cumplimiento-sat-scraper",
  "description": "Web Scraping para extraer la Opinión de Cumplimiento desde la página del SAT",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Cesar Aguilera",
      "email": "cesargnu29@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "PhpCfdi\\OpinionCumplimientoSatScraper\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PhpCfdi\\OpinionCumplimientoSatScraper\\Tests\\": "tests/"
    }
  },
  "require": {
    "ext-curl": "*",
    "guzzlehttp/guzzle": "^7.0",
    "symfony/dom-crawler": "^7.0 || ^8.0",
    "symfony/css-selector": "^7.0 || ^8.0",
    "symfony/browser-kit": "^8.0",
    "symfony/http-client": "^8.0",
    "phpcfdi/image-captcha-resolver": "^0.3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^4.0"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "scripts": {
    "test": "phpunit",
    "test-coverage": "phpunit --coverage-html coverage",
    "dev:check-style": [
      "@php vendor/bin/phpcs --colors -sp"
    ],
    "dev:fix-style": [
      "@php vendor/bin/phpcbf --colors -sp"
    ],
    "dev:build": [
      "@dev:fix-style",
      "@test"
    ]
  },
  "scripts-descriptions": {
    "test": "Run PHPUnit tests",
    "test-coverage": "Run PHPUnit tests with code coverage",
    "dev:check-style": "DEV: search for code style errors using phpcs",
    "dev:fix-style": "DEV: fix code style errors using phpcbf",
    "dev:build": "DEV: run dev:fix-style and test, run before pull request"
  }
}
